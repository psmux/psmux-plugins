# =============================================================================
# Example psmux configuration with plugins
# Save as: ~/.psmux.conf  (or %USERPROFILE%\.psmux.conf)
# =============================================================================
# Plugins are loaded via source-file (static .conf files).
# Install plugins to ~/.psmux/plugins/ first, then source their plugin.conf.
#
# To install all plugins at once, run in PowerShell:
#   pwsh ~/.psmux/plugins/ppm/ppm.ps1
# =============================================================================

# --- General Settings (override sensible defaults if needed) ---
# set -g prefix C-a                    # Change prefix to Ctrl+a (default: C-b)
# unbind-key C-b
# bind-key C-a send-prefix

# --- Shell ---
# set -g default-shell pwsh            # PowerShell 7 (default)
# set -g default-shell cmd             # cmd.exe
# set -g default-shell nu              # nushell

# --- Cursor ---
set -g cursor-style bar               # bar, block, or underline
set -g cursor-blink on

# =============================================================================
# PLUGINS (loaded via source-file)
# =============================================================================

# Sensible defaults (escape-time, history, mouse, vi mode, base-index, etc.)
source-file ~/.psmux/plugins/psmux-sensible/plugin.conf

# Vim-style pane navigation: h/j/k/l nav, Alt+h/j/k/l resize
source-file ~/.psmux/plugins/psmux-pain-control/plugin.conf

# NOTE: Clipboard integration (y to copy, right-click paste) is built into psmux natively.
# No plugin needed for clipboard support.

# Prefix key indicator in status bar
source-file ~/.psmux/plugins/psmux-prefix-highlight/plugin.conf

# Battery status (Prefix+b for info)
source-file ~/.psmux/plugins/psmux-battery/plugin.conf

# CPU/RAM status (Prefix+Ctrl-c for info)
source-file ~/.psmux/plugins/psmux-cpu/plugin.conf

# Pane output logging (Alt-o=toggle, Alt-p=screenshot, Alt-i=history)
source-file ~/.psmux/plugins/psmux-logging/plugin.conf

# Directory tree sidebar (Tab/Shift-Tab)
source-file ~/.psmux/plugins/psmux-sidebar/plugin.conf

# Session save/restore (Ctrl-s=save, Ctrl-r=restore)
source-file ~/.psmux/plugins/psmux-resurrect/plugin.conf

# Auto-save sessions every 15 minutes
source-file ~/.psmux/plugins/psmux-continuum/plugin.conf

# =============================================================================
# THEME (uncomment exactly ONE — must be LAST to override status bar)
# =============================================================================
# source-file ~/.psmux/plugins/psmux-theme-dracula/plugin.conf
# source-file ~/.psmux/plugins/psmux-theme-catppuccin/plugin.conf
# source-file ~/.psmux/plugins/psmux-theme-nord/plugin.conf
# source-file ~/.psmux/plugins/psmux-theme-tokyonight/plugin.conf
source-file ~/.psmux/plugins/psmux-theme-gruvbox/plugin.conf
